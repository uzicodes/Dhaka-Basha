generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 2. The User Model 
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  phone     String?  
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings  Listing[] // A user can have many To-Let posts
}

// 3. The To-Let Listing Model
model Listing {
  id           String       @id @default(cuid())
  title        String
  description  String
  rentPrice    Int          // In BDT
  rentFrom     String       // e.g., "05/2026"
  contactInfo  String       // e.g., "017XXXXXXXX"
  mapLink      String?
  
  location     String
  propertyType String
  subLocation  String?
  
  address      String?      // Exact house number/road (optional)
  images       String[]     // Array of Cloudinary Image URLs
  
  isAvailable  Boolean      @default(true)
  
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relationship to the User who posted it
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}