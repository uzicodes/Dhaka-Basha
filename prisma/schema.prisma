generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

// 1. The User Model 
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  phone     String?  
  address   String?
  profileImage String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings      Listing[]      // A user can CREATE many To-Let posts
  savedListings SavedListing[] // A user can SAVE many To-Let posts

  // Messaging Relations
  conversationsStarted Conversation[] @relation("ConversationUser1")
  conversationsReceived Conversation[] @relation("ConversationUser2")
  messagesSent          Message[]
}

// 4. The Conversation Model (1-on-1 between two users)
model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user1Id   String
  user1     User     @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)

  user2Id   String
  user2     User     @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)

  messages  Message[]

  @@unique([user1Id, user2Id])
}

// 5. The Message Model
model Message {
  id        String   @id @default(cuid())
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// 2. The To-Let Listing Model
model Listing {
  id           String   @id @default(cuid())
  title        String
  rentPrice    Int
  propertyType String
  location     String
  subLocation  String?
  rentFrom     String
  address      String
  contactInfo  String
  mapLink      String?
  images       String[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relationship to the User who posted it
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relationship to the Users who saved it
  savedBy      SavedListing[] 
}

// 3. The Explicit Join Table for Saved Posts
model SavedListing {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) // Tracks exactly when the user saved it

  // Link to the User
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Link to the Listing
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  // This prevents a user from saving the exact same post multiple times
  @@unique([userId, listingId]) 
}